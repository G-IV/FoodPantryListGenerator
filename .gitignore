# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Release build files
*.iobj
*.exe.recipe

# Debug files
*.dSYM/
*.su
*.idb
*.pdb
*.ipdb
*.log
*.tlog
*.lastbuildstate

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# CSV files — ignore all by default; real pantry data must never be committed
*.csv
# Explicitly ignore the runtime invalid-number list (contains real case numbers + admin contact)
InvNmbrs.csv
# Allow synthetic sample fixtures used for testing
!tests/fixtures/*.csv
# Explicitly protect the real pantry reports directory (contains PII)
docs/prev_reports/

# vcxproj files
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# Files I think are unnecessary, but not sure about
*.VC.db
*.suo
*.vsidx
*.ipch
# Python
__pycache__/
*.py[cod]
*.pyo
.Python

# PyInstaller build output
build/
dist/
*.spec

# Virtual environments
.venv/
venv/
env/

# pytest cache
.pytest_cache/

# Developer test output — CSV files written during local scanner testing
dev/output/*.csv
